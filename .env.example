# Clés Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Secret du webhook Stripe (stripe listen --print-secret, ou depuis le dashboard)
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# URL publique du site (utilisée pour les redirections Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E-mail transactionnel (https://resend.com/api-keys) — facultatif :
# tant que RESEND_API_KEY n'est pas défini, l'envoi est simplement ignoré.
RESEND_API_KEY=your_resend_api_key_here
ORDER_FROM_EMAIL=Somnia <onboarding@resend.dev>

# CJ Dropshipping (https://developers.cjdropshipping.com) — facultatif :
# tant que CJ_API_KEY n'est pas défini, la commande fournisseur n'est pas
# déclenchée automatiquement (à faire manuellement en attendant).
CJ_API_KEY=your_cj_api_key_here
CJ_LOGISTIC_NAME=CJPacket Ordinary
CJ_FROM_COUNTRY_CODE=CN

# Gestion de la TVA à l'import UE (IOSS) — 3 = CJ gère l'IOSS pour toi
# (par défaut, le plus simple). Mets 2 + CJ_IOSS_NUMBER si tu as ton propre
# numéro IOSS, ou 1 si tu ne veux pas d'IOSS du tout.
CJ_IOSS_TYPE=3
CJ_IOSS_NUMBER=
